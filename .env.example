# ===================================
# Finance Analysis - 环境变量配置模板
# 复制此文件为 .env 并填入真实配置
# ===================================


# Anspire Open API Keys（支持多个，逗号分隔）
# 获取: https://open.anspire.cn/?share_code=QFBC0FYC
# 在未配置更高优先级 OpenAI-compatible 来源时，满足条件可复用该 key 给 Anspire 大模型网关与新闻搜索。
# 下列网关与模型为当前项目示例配置；是否可用请以 Anspire 控制台与官方文档为准：
# 示例网关： https://open-gateway.anspire.cn/v6
# 示例模型：Doubao-Seed-2.0-lite（可覆盖为 ANSPIRE_LLM_MODEL=Doubao-Seed-2.0-pro）
# 若网关有区域/版本差异，可覆盖为 ANSPIRE_LLM_BASE_URL=https://open-gateway.anspire.ai/v6
ANSPIRE_API_KEYS=
# ANSPIRE_LLM_MODEL=Doubao-Seed-2.0-lite
# ANSPIRE_LLM_BASE_URL=https://open-gateway.anspire.cn/v6
# ANSPIRE_LLM_ENABLED=true
# 数据源配置
# 东方财富反爬补丁（可选）：true/false，默认 false。
# 仅在访问东方财富接口被风控时开启；开启后会为相关请求注入随机 UA 与授权 Cookie 并随机休眠。
# ENABLE_EASTMONEY_PATCH=false
# Tushare Pro Token（可选，从 https://tushare.pro/weborder/#/login?reg=834638 获取）
TUSHARE_TOKEN=
# TickFlow API Key（可选，用于 A 股大盘复盘指数增强；若套餐支持标的池查询，也可增强市场统计）
# TICKFLOW_API_KEY=
# Longbridge OpenAPI（可选，美股/港股量比、换手率、PE 等字段兜底）
# 从 https://open.longbridge.com/ 获取
# LONGBRIDGE_APP_KEY=
# LONGBRIDGE_APP_SECRET=
# LONGBRIDGE_ACCESS_TOKEN=
# static_info 进程内缓存秒数，默认 86400；0=每次请求拉取
# LONGBRIDGE_STATIC_INFO_TTL_SECONDS=86400
# 连接关闭类异常后的冷却秒数，默认 15；冷却期内会临时跳过 Longbridge，避免请求级频繁重连
# LONGBRIDGE_CONNECTION_COOLDOWN_SECONDS=15

# 历史行情同步窗口与 Provider 任务级并发/重试。
# MARKET_DATA_INITIAL_DAILY_DAYS=1095
# MARKET_DATA_INITIAL_MINUTE_DAYS=3
# MARKET_DATA_REPAIR_DAILY_DAYS=14
# MARKET_DATA_REPAIR_MINUTE_DAYS=3
# MARKET_DATA_LONGBRIDGE_MAX_CONCURRENCY=5
# MARKET_DATA_LONGBRIDGE_MAX_RETRIES=3
# MARKET_DATA_YFINANCE_MAX_CONCURRENCY=3
# MARKET_DATA_YFINANCE_MAX_RETRIES=2
# Longbridge SDK 语言与 REPORT_LANGUAGE（zh/en）一致；SDK 日志写入 data/logs/app/longbridge_sdk.log
# 接入点（与 REPORT_LANGUAGE 无关；留空则用下列默认值）：
# LONGBRIDGE_HTTP_URL=https://openapi.longbridge.com
# LONGBRIDGE_QUOTE_WS_URL=wss://openapi-quote.longbridge.com/v2
# LONGBRIDGE_TRADE_WS_URL=wss://openapi-trade.longbridge.com/v2
# LONGBRIDGE_REGION=hk
# 覆盖接入点；SDK 内部用 LONGPORT_REGION（不带 BRIDGE）自动选择，
# 代码会自动同步 LONGBRIDGE_REGION → LONGPORT_REGION。
# hk → *.longbridge.com  |  cn → *.longbridge.cn
# 其余见：https://open.longbridge.com/zh-CN/docs/getting-started#环境变量
# 夜盘行情 true/false，默认 false
# LONGBRIDGE_ENABLE_OVERNIGHT=false
# K 线推送 realtime 或 confirmed，默认 realtime
# LONGBRIDGE_PUSH_CANDLESTICK_MODE=realtime
# 连接时是否打印行情包（与 README / full-guide 一致：未设置时应用侧默认为关闭，等同 false）
# 设为 1 / true / yes 开启 SDK 详细行情包日志（调试长桥连接时使用）
# LONGBRIDGE_PRINT_QUOTE_PACKAGES=false

# ===================================
# AI 模型配置（LiteLLM 统一调用）
# ===================================
# 所有 LLM 请求统一走应用内 LiteLLM client，模型名使用 LiteLLM 格式（provider/model）。
#
# 示例（OpenAI 兼容网关）：
# LLM_MODEL=openai/gpt-5.5
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-xxx
#
# 示例（Gemini 官方）：
# LLM_MODEL=gemini/gemini-3.1-pro-preview
# LLM_API_KEY=your-gemini-key
#
# 示例（Ollama 本地，无需 API Key）：
# LLM_MODEL=ollama/qwen3:8b
# LLM_BASE_URL=http://localhost:11434
#
# 可选：主模型失败时按顺序重试
# LLM_FALLBACK_MODELS=openai/gpt-4.1-mini,anthropic/claude-sonnet-4-6
#
# 采样温度（0.0-2.0，默认 0.7）
# LLM_TEMPERATURE=0.7
#
# Agent 可单独指定主模型（留空则继承 LLM_MODEL）
# AGENT_LITELLM_MODEL=
#
# 图片识别可选覆盖（留空则使用 LLM_MODEL）
# VISION_MODEL=

LLM_MODEL=
LLM_BASE_URL=
LLM_API_KEY=

# 可选：单次请求切换到 LLM Web API（provider="llm_web"）时使用。
# 默认值在代码中维护：
# LLM_WEB_MODEL=gemini-3.5-flash
# LLM_WEB_BASE_URL=http://host.docker.internal:8001/v1
LLM_WEB_API_KEY=


# ===================================
# 搜索引擎配置（用于获取股票新闻）
# ===================================
# Bocha API Keys（中文搜索优化，支持AI摘要，支持多个，逗号分隔）
# 获取: https://open.bocha.cn/
# BOCHA_API_KEYS=your_bocha_key_here
# MiniMax API Key（Coding Plan Web Search，支持多个，逗号分隔）
# 获取: https://platform.minimax.io/
# MINIMAX_API_KEYS=your_minimax_key_here
# Tavily API Keys（支持多个，逗号分隔）
TAVILY_API_KEYS=
# SerpAPI Keys（支持多个，逗号分隔）
SERPAPI_API_KEYS=
# Brave Search API Keys（支持多个，逗号分隔）
# 获取: https://brave.com/search/api/
BRAVE_API_KEYS=
# SearXNG 实例地址（逗号分隔，私有部署无配额，需在 settings.yml 启用 format: json）
# 留空时默认自动从 searx.space 拉取公共实例；若不希望访问公共实例，可将下方开关设为 false
SEARXNG_BASE_URLS=
SEARXNG_PUBLIC_INSTANCES_ENABLED=true

# ===================================
# Social Sentiment Intelligence (US stocks only)
# ===================================
# Reddit / X (Twitter) / Polymarket sentiment data from api.adanos.org
# Only activates for US stock tickers (AAPL, TSLA, etc.), ignored for A-shares/HK stocks
# Free tier: 250 requests/month | Register: https://api.adanos.org
# SOCIAL_SENTIMENT_API_KEY=sk_live_your_key_here
# SOCIAL_SENTIMENT_API_URL=https://api.adanos.org


# ===================================
# 通知渠道配置（可同时配置多个，全部推送）
# ===================================
#
# 如果机器人安全设置开启了“签名校验”，需同步填写 secret
# 如果机器人安全设置开启了“关键词”，需填写同一个关键词；系统会自动在每条消息前补上
#
# 【方式一】Telegram 机器人（需同时配置两项）
# 1. 在 Telegram 找 @BotFather -> /newbot -> 获取 Bot Token
# 2. 获取 Chat ID：发消息给 @userinfobot 或访问 https://api.telegram.org/bot<token>/getUpdates
#
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_CHAT_ID=123456789
# TELEGRAM_MESSAGE_THREAD_ID=2780
#
# 【方式二】邮件推送（只需 2 项配置，SMTP 自动识别）
# 支持 QQ邮箱、163邮箱、Gmail 等支持 SMTP 授权码/基础认证的邮箱
# Outlook / Exchange 若租户强制 OAuth2，当前版本暂不支持
# 1. 获取授权码（以QQ邮箱为例）：设置 -> 账户 -> POP3/SMTP服务 -> 开启 -> 获取授权码
# 2. 填写下面两项即可：
#
# EMAIL_SENDER=
# EMAIL_PASSWORD=
# EMAIL_RECEIVERS=receiver@example.com  # 可选，留空则发给自己
#
# 【方式二扩展】股票分组发往不同邮箱（Issue #268，可选）
# STOCK_LIST 决定实际分析范围；STOCK_GROUP_N 仅决定邮件发给谁，建议始终写成 STOCK_LIST 的子集
# Telegram / Webhook 等其他渠道仍会按完整 STOCK_LIST 推送，不会因为分组而拆分
# 当前仓库默认 GitHub Actions daily_analysis workflow 不会自动注入任意编号的 STOCK_GROUP_N / EMAIL_GROUP_N
# 因此该能力适用于本地 .env、Docker，或其他已显式注入这些变量的运行环境
# STOCK_GROUP_1=600519,300750
# EMAIL_GROUP_1=user1@example.com
# STOCK_GROUP_2=002594,AAPL
# EMAIL_GROUP_2=user2@example.com
#
# 【方式三】自定义 Webhook（支持多个，逗号分隔）
# 适用于：Bark、Discord、Slack、自建服务等任意支持 POST JSON 的 Webhook
# 系统会自动识别常见服务并使用对应格式
#
# CUSTOM_WEBHOOK_URLS=https://api.day.app/YOUR_BARK_KEY
# CUSTOM_WEBHOOK_BEARER_TOKEN=  # 可选，用于需要认证的 Webhook (Header Authorization: Bearer <token>)
# CUSTOM_WEBHOOK_BODY_TEMPLATE=  # 可选，全局 JSON body 模板，会覆盖 Bark 等自动 payload；推荐 $content_json/$title_json
# WEBHOOK_VERIFY_SSL=true   # 默认校验；影响读取该配置的 webhook-style HTTPS 通知请求。设为 false 可支持自签名证书。警告：禁用后存在 MITM 劫持风险，仅限可信内网
#
#
# 【方式四】ntfy 配置
# NTFY_URL 必须包含 topic path，例如 https://ntfy.sh/my-topic 或 https://self-hosted:port/my-topic
# 系统会解析 topic，并使用 ntfy JSON publish API 发送 Markdown 文本。
# NTFY_URL=
# NTFY_TOKEN=  # 可选，用于需要 Bearer Token 的 topic 或自建 ntfy server
#
#
#
# 【方式五】AstrBot 配置
# ASTRBOT_URL=
# ASTRBOT_TOKEN=  # 可选，用于需要 Bearer Token 的 AstrBot Webhook

# ===================================
# 数据库配置
# ===================================
#
# 【推荐】PostgreSQL 连接串（Docker Compose 已自动注入，单机开发可手动填写）
# 格式：postgresql+psycopg2://<user>:<password>@<host>:<port>/<dbname>
# Docker Compose 环境会自动覆盖此值，连接到内部 postgres 容器。
#
# PostgreSQL 凭据（docker-compose 中 postgres 服务使用，需与 DATABASE_URL 一致）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=finance_analysis

# 必填：PostgreSQL 连接（与 docker-compose.dev.yml 中 postgres 服务一致）
DATABASE_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Redis 直连配置（Docker Compose 已自动注入，单机开发可手动填写）
REDIS_URL=redis://redis:6379/0

# ===================================
# 长桥实时行情 streamer（可选）
# ===================================
# 留空时复用 REDIS_URL，不要求独立 Redis 实例
REALTIME_REDIS_URL=

# ===================================
# Web 登录认证
# ===================================
# 默认启用密码保护；合法用户邮箱须预先写入数据库（首次登录在网页设置密码）
# 用于签名登录 JWT Cookie；留空时首次使用时自动随机生成（未写入 .env 则重启后会话可能失效）
# 生产环境请设置为足够长的随机字符串
SECRET_KEY=
